# PatchPilot environment template — copy to .env and fill in real values.
# .env is gitignored; NEVER commit real secrets.

# --- Primary provider: OpenAI (gpt-4o-mini) ---
# Paste your OpenAI sk-... key here. Required for cognee's cognify() graph extraction.
LLM_API_KEY=
LLM_PROVIDER=openai
# Pinned explicitly — cognee's own .env.template default is now openai/gpt-5-mini,
# which would blow the $10 budget cap. Do NOT change this without updating the cap.
LLM_MODEL=openai/gpt-4o-mini

# --- Persistence (Cognee reads these at import time — must be set BEFORE `import cognee`) ---
# Absolute paths under this repo's .patchpilot_memory/ directory.
# Example: /Users/you/dev/patch-pilot/.patchpilot_memory
SYSTEM_ROOT_DIRECTORY=
# Example: /Users/you/dev/patch-pilot/.patchpilot_memory/data
DATA_ROOT_DIRECTORY=

# --- Fallback: Google Gemini free tier (no OpenAI key needed, $0) ---
# Use this path ONLY if no OpenAI key is available. Uncomment the four lines below,
# comment out the OpenAI LLM_PROVIDER/LLM_MODEL lines above, and paste a Google AI
# Studio free-tier key into LLM_API_KEY (same slot as the OpenAI key above).
# Exact cognee 1.2.2 var names for this path are verified empirically in the Task 3
# spike (help()/docs) before being relied upon elsewhere.
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini/gemini-1.5-flash
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=gemini/text-embedding-004
